{
  "budget": {
    "monthlyBudgetUsd": 50.0,
    "alertThresholdPct": 80.0
  },
  "permissions": {
    "deny": [
      "Bash(*rm -rf*)",
      "Bash(*git push --force*)",
      "Bash(*git push -f*)",
      "Bash(*git reset --hard*)",
      "Read(**/*.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/*secrets*)",
      "Edit(**/*.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(**/*.env*)",
      "Write(**/*.pem)"
    ]
  }
}
