{
  "budget": {
    "monthlyBudgetUsd": 50.0,
    "alertThresholdPct": 80.0
  },
  "permissions": {
    "deny": [
      "Bash(command:*rm -rf*)",
      "Bash(command:*git push --force*)",
      "Bash(command:*git push -f*)",
      "Bash(command:*git reset --hard*)",
      "Read(file_path:*.env*)",
      "Read(file_path:*.pem)",
      "Read(file_path:*.key)",
      "Read(file_path:*credentials*)",
      "Read(file_path:*secrets*)",
      "Edit(file_path:*.env*)",
      "Edit(file_path:*.pem)",
      "Edit(file_path:*.key)",
      "Write(file_path:*.env*)",
      "Write(file_path:*.pem)",
      "Write(file_path:*.key)"
    ]
  }
}
