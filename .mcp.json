{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "${CLAUDE_PROJECT_DIR}"
      ],
      "env": {
        "CLAUDE_PROJECT_DIR": "${CLAUDE_PROJECT_DIR}"
      }
    },
    "grepai": {
      "type": "stdio",
      "command": "grepai",
      "args": ["mcp-serve"],
      "env": {
        "GREPAI_PROJECT_PATH": "${CLAUDE_PROJECT_DIR}"
      }
    },
    "tree-sitter": {
      "type": "stdio",
      "command": "mcp-server-tree-sitter",
      "args": []
    }
  }
}
